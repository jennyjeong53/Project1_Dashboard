```{r}
#| context: setup

library(tidyverse)
library(scales)
library(gt)

bank_raw <- read_delim(
  "bank-additional-full.csv",
  delim = ";",
  show_col_types = FALSE
)

names(bank_raw) <- names(bank_raw) |>
  str_replace_all("\\.", "_")

bank <- bank_raw |>
  mutate(
    subscribed = if_else(y == "yes", "Subscribed", "Not Subscribed"),
    subscribed = factor(subscribed, levels = c("Not Subscribed", "Subscribed")),
    age_group = case_when(
      age < 30 ~ "Under 30",
      age >= 30 & age < 40 ~ "30-39",
      age >= 40 & age < 50 ~ "40-49",
      age >= 50 & age < 60 ~ "50-59",
      TRUE ~ "60+"
    ),
    age_group = factor(age_group, levels = c("Under 30", "30-39", "40-49", "50-59", "60+")),
    month = factor(month, levels = c("mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec")),
    contact = str_to_title(contact),
    poutcome = str_to_title(poutcome),
    job = str_replace_all(job, "\\.", " ") |> str_to_title(),
    education = str_replace_all(education, "\\.", " ") |> str_to_title(),
    y_binary = if_else(y == "yes", 1, 0)
  )

total_contacts <- nrow(bank)
total_subscribed <- sum(bank$y == "yes")
subscription_rate <- mean(bank$y == "yes")
avg_duration <- mean(bank$duration)

subscription_by_group <- function(data, group_var) {
  data |>
    group_by({{ group_var }}) |>
    summarise(
      contacts = n(),
      subscriptions = sum(y == "yes"),
      subscription_rate = subscriptions / contacts,
      .groups = "drop"
    )
}
```

