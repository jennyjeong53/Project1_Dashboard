```{r}
# Load packages
library(tidyverse)
library(plotly)
library(knitr)
library(scales)
library(bslib)

# Read data
# Put this QMD file and the CSV file in the same folder.
# If your CSV has a different name, change the file name below.
if (file.exists("bank-additional-full.csv")) {
  bank <- read.csv("bank-additional-full.csv", sep = ";")
} else if (file.exists("bank-additional-full(2).csv")) {
  bank <- read.csv("bank-additional-full(2).csv", sep = ";")
} else {
  stop("CSV file not found. Please place bank-additional-full.csv in the same folder as this QMD file.")
}

# Clean and prepare variables
bank <- bank |>
  mutate(
    subscribed = if_else(y == "yes", 1, 0),
    y = factor(y, levels = c("no", "yes")),
    age_group = cut(
      age,
      breaks = c(0, 29, 39, 49, 59, 100),
      labels = c("Under 30", "30-39", "40-49", "50-59", "60+"),
      right = TRUE
    ),
    contact = str_to_title(contact),
    month = factor(month, levels = c("mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec")),
    month_name = fct_recode(
      month,
      "Mar" = "mar", "Apr" = "apr", "May" = "may", "Jun" = "jun",
      "Jul" = "jul", "Aug" = "aug", "Sep" = "sep", "Oct" = "oct",
      "Nov" = "nov", "Dec" = "dec"
    ),
    previous_contact = if_else(previous > 0, "Previously contacted", "Not previously contacted"),
    duration_min = duration / 60
  )

overall_subscription_rate <- mean(bank$subscribed)
total_contacts <- nrow(bank)
total_subscriptions <- sum(bank$subscribed)
avg_duration <- mean(bank$duration_min)

subscription_by_job <- bank |>
  group_by(job) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  ) |>
  filter(contacts >= 100) |>
  arrange(subscription_rate)

subscription_by_age <- bank |>
  group_by(age_group) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

subscription_by_month <- bank |>
  group_by(month_name) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

subscription_by_contact <- bank |>
  group_by(contact) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

subscription_by_previous <- bank |>
  group_by(previous_contact) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

econ_summary <- bank |>
  group_by(y) |>
  summarise(
    avg_euribor3m = mean(euribor3m),
    avg_employment = mean(nr.employed),
    avg_cons_conf = mean(cons.conf.idx),
    .groups = "drop"
  )
```

