  geom_col() +
  scale_y_continuous(labels = percent) +
  labs(
    title = "Subscription behavior changes with economic conditions",
    subtitle = "The Euribor 3-month rate is one external indicator linked to customer response.",
    x = "Euribor 3-month rate group",
