# -----------------------------------------------------------------------------
# Data
# -----------------------------------------------------------------------------

if (file.exists("bank-additional-full.csv")) {
  data_path <- "bank-additional-full.csv"
} else if (file.exists("bank-additional-full(2).csv")) {
  data_path <- "bank-additional-full(2).csv"
} else {
  stop("Please place bank-additional-full.csv in the same folder as app.R")
}

bank_raw <- read.csv(data_path, sep = ";", stringsAsFactors = FALSE, check.names = FALSE)

month_levels <- c("jan", "feb", "mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec")
month_labels <- c("Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec")

bank <- bank_raw %>%
  mutate(
    subscribed = y == "yes",
    subscription = if_else(subscribed, "Subscribed", "Not Subscribed"),
    month = factor(month, levels = month_levels, labels = month_labels),
    age_group = case_when(
      age < 30 ~ "Under 30",
      age < 40 ~ "30-39",
      age < 50 ~ "40-49",
      age < 60 ~ "50-59",
      TRUE ~ "60+"
    ),
    previous_contact = if_else(previous > 0, "Previously contacted", "Not previously contacted"),
    campaign_intensity = case_when(
      campaign == 1 ~ "1 contact",
      campaign <= 3 ~ "2-3 contacts",
      TRUE ~ "4+ contacts"
    ),
    # The original data has month and day-of-week but no exact calendar date.
    # This constructed timeline preserves record order and allows date-range filtering
    # for the interactive app requirement.
    campaign_date = seq.Date(as.Date("2008-05-01"), as.Date("2010-11-30"), length.out = n())
  )

segment_choices <- c(
  "Age Group" = "age_group",
  "Job Type" = "job",
  "Education" = "education",
  "Marital Status" = "marital",
  "Housing Loan" = "housing",
  "Personal Loan" = "loan",
  "Previous Contact" = "previous_contact"
)

campaign_choices <- c(
  "Contact Method" = "contact",
  "Month" = "month",
  "Day of Week" = "day_of_week",
  "Previous Campaign Outcome" = "poutcome",
  "Campaign Intensity" = "campaign_intensity"
)

numeric_choices <- c(
  "Call Duration" = "duration",
  "Number of Campaign Contacts" = "campaign",
  "Previous Contacts" = "previous",
  "Employment Variation Rate" = "emp.var.rate",
  "Consumer Price Index" = "cons.price.idx",
  "Consumer Confidence Index" = "cons.conf.idx",
  "Euribor 3 Month Rate" = "euribor3m",
  "Number of Employees" = "nr.employed"
)

