```{r}
# Load packages
library(tidyverse)
library(plotly)
library(knitr)
library(scales)
library(bslib)
library(bsicons)

# Read data
# Put this QMD file and the CSV file in the same folder.
# If your CSV has a different name, change the file name below.
if (file.exists("bank-additional-full.csv")) {
  bank <- read.csv("bank-additional-full.csv", sep = ";")
} else if (file.exists("bank-additional-full(2).csv")) {
  bank <- read.csv("bank-additional-full(2).csv", sep = ";")
} else {
  stop("CSV file not found. Please place bank-additional-full.csv in the same folder as this QMD file.")
}

# Y2K pastel palette
pink <- "#FFB6C1"
hot_pink <- "#FF69B4"
mint <- "#B8F2E6"
aqua <- "#9BF6FF"
yellow <- "#FFF3B0"
lavender <- "#D8B4F8"
peach <- "#FFD6A5"
rose <- "#FF8FAB"
cream <- "#FFFDF8"
ink <- "#42405A"
pastel_palette <- c(pink, mint, yellow, aqua, lavender, peach, rose, "#CDEAC0", "#FFC6FF", "#CAFFBF", "#FDFFB6", "#A0C4FF")

# Shared ggplot theme
pastel_theme <- theme_minimal(base_size = 14) +
  theme(
    plot.title = element_text(face = "bold", size = 17, color = ink),
    plot.subtitle = element_text(size = 11, color = "#6f6b86"),
    axis.title = element_text(face = "bold", color = ink),
    axis.text = element_text(color = ink),
    panel.grid.minor = element_blank(),
    panel.grid.major = element_line(color = "#efeaf7", linewidth = 0.35),
    plot.background = element_rect(fill = cream, color = NA),
    panel.background = element_rect(fill = cream, color = NA),
    legend.position = "none",
    legend.title = element_blank(),
    plot.margin = margin(8, 14, 18, 14)
  )

# Clean and prepare variables
bank <- bank |>
  mutate(
    subscribed = if_else(y == "yes", 1, 0),
    y = factor(y, levels = c("no", "yes"), labels = c("No", "Yes")),
    age_group = cut(
      age,
      breaks = c(0, 29, 39, 49, 59, 100),
      labels = c("Under 30", "30-39", "40-49", "50-59", "60+"),
      right = TRUE
    ),
    contact = str_to_title(contact),
    month = factor(month, levels = c("mar", "apr", "may", "jun", "jul", "aug", "sep", "oct", "nov", "dec")),
    month_name = fct_recode(
      month,
      "Mar" = "mar", "Apr" = "apr", "May" = "may", "Jun" = "jun",
      "Jul" = "jul", "Aug" = "aug", "Sep" = "sep", "Oct" = "oct",
      "Nov" = "nov", "Dec" = "dec"
    ),
    previous_contact = if_else(previous > 0, "Prior contact", "No prior contact"),
    duration_min = duration / 60
  )

overall_subscription_rate <- mean(bank$subscribed)
total_contacts <- nrow(bank)
total_subscriptions <- sum(bank$subscribed)
avg_duration <- mean(bank$duration_min)

subscription_by_job <- bank |>
  group_by(job) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  ) |>
  filter(contacts >= 100) |>
  arrange(subscription_rate)

subscription_by_age <- bank |>
  group_by(age_group) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

subscription_by_month <- bank |>
  group_by(month_name) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

subscription_by_contact <- bank |>
  group_by(contact) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

subscription_by_previous <- bank |>
  group_by(previous_contact) |>
  summarise(
    contacts = n(),
    subscription_rate = mean(subscribed),
    .groups = "drop"
  )

econ_summary <- bank |>
  group_by(y) |>
  summarise(
    avg_euribor3m = mean(euribor3m),
    avg_employment = mean(nr.employed),
    avg_cons_conf = mean(cons.conf.idx),
    .groups = "drop"
  )
```

