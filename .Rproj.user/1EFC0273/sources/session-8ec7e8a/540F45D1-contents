# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

server <- function(input, output, session) {

  filtered_data <- reactive({
    bank %>%
      filter(
        campaign_date >= input$date_range[1],
        campaign_date <= input$date_range[2],
        contact %in% input$contact_filter,
        poutcome %in% input$outcome_filter
      )
  })

  output$total_contacts <- renderText({
    comma(nrow(filtered_data()))
  })

  output$subscription_rate <- renderText({
    percent(mean(filtered_data()$subscribed), accuracy = 0.1)
  })

  output$subscribed_count <- renderText({
    comma(sum(filtered_data()$subscribed))
  })

  output$avg_duration <- renderText({
    paste0(round(mean(filtered_data()$duration), 1), " sec")
  })

  output$trend_plot <- renderPlotly({
    df <- filtered_data() %>%
      mutate(period = floor_date(campaign_date, "month")) %>%
      group_by(period) %>%
      summarise(
        contacts = n(),
        subscription_rate = mean(subscribed),
        .groups = "drop"
      )

    plot_ly(
      df,
      x = ~period,
      y = ~subscription_rate,
      type = "scatter",
      mode = "lines+markers",
      line = list(color = "#ff69b4", width = 4),
      marker = list(color = "#9bf6ff", size = 8, line = list(color = "#3f3d63", width = 1)),
      text = ~paste0("Date: ", period, "<br>Subscription Rate: ", percent(subscription_rate, accuracy = 0.1), "<br>Contacts: ", comma(contacts)),
      hoverinfo = "text"
    ) %>%
      layout(
        xaxis = list(title = "Campaign Timeline"),
        yaxis = list(title = "Subscription Rate", tickformat = ".0%"),
        paper_bgcolor = "rgba(0,0,0,0)",
        plot_bgcolor = "rgba(255,253,248,0.8)",
        margin = list(l = 60, r = 20, t = 20, b = 60)
      )
  })

  output$numeric_trend_plot <- renderPlotly({
    req(input$numeric_var)
    df <- filtered_data() %>%
      mutate(period = floor_date(campaign_date, "month")) %>%
      group_by(period) %>%
      summarise(avg_value = mean(.data[[input$numeric_var]], na.rm = TRUE), .groups = "drop")

    selected_label <- names(numeric_choices)[numeric_choices == input$numeric_var]

    plot_ly(
      df,
      x = ~period,
      y = ~avg_value,
      type = "scatter",
      mode = "lines+markers",
      line = list(color = "#55d6c2", width = 4),
      marker = list(color = "#fff3b0", size = 8, line = list(color = "#3f3d63", width = 1)),
      text = ~paste0("Date: ", period, "<br>", selected_label, ": ", round(avg_value, 2)),
      hoverinfo = "text"
    ) %>%
      layout(
        xaxis = list(title = "Campaign Timeline"),
        yaxis = list(title = selected_label),
        paper_bgcolor = "rgba(0,0,0,0)",
        plot_bgcolor = "rgba(255,253,248,0.8)",
        margin = list(l = 60, r = 20, t = 20, b = 60)
      )
  })

  output$segment_plot <- renderPlotly({
    req(input$segment_var)
    selected_label <- names(segment_choices)[segment_choices == input$segment_var]

    df <- filtered_data() %>%
      group_by(group = .data[[input$segment_var]]) %>%
      summarise(
        contacts = n(),
        subscription_rate = mean(subscribed),
        .groups = "drop"
      ) %>%
      filter(!is.na(group)) %>%
      arrange(desc(subscription_rate)) %>%
      slice_head(n = 12)

    plot_ly(
      df,
      x = ~subscription_rate,
      y = ~reorder(group, subscription_rate),
      type = "bar",
      orientation = "h",
      marker = list(color = c("#ffb6c1", "#b8f2e6", "#fff3b0", "#9bf6ff", "#d8b4f8", "#ffd6a5")),
      text = ~paste0(percent(subscription_rate, accuracy = 0.1), "<br>Contacts: ", comma(contacts)),
      hoverinfo = "text"
    ) %>%
      layout(
        xaxis = list(title = "Subscription Rate", tickformat = ".0%"),
        yaxis = list(title = selected_label),
        paper_bgcolor = "rgba(0,0,0,0)",
        plot_bgcolor = "rgba(255,253,248,0.8)",
        margin = list(l = 120, r = 20, t = 20, b = 60)
      )
  })

  output$campaign_plot <- renderPlotly({
    req(input$campaign_var)
    selected_label <- names(campaign_choices)[campaign_choices == input$campaign_var]

    df <- filtered_data() %>%
      group_by(group = .data[[input$campaign_var]]) %>%
      summarise(
        contacts = n(),
        subscription_rate = mean(subscribed),
        .groups = "drop"
      ) %>%
      filter(!is.na(group)) %>%
      arrange(desc(subscription_rate))

    plot_ly(
      df,
      x = ~group,
      y = ~subscription_rate,
      type = "bar",
      marker = list(color = c("#b8f2e6", "#ffb6c1", "#fff3b0", "#d8b4f8", "#9bf6ff", "#ffd6a5")),
      text = ~percent(subscription_rate, accuracy = 0.1),
      textposition = "outside",
      hovertext = ~paste0(selected_label, ": ", group, "<br>Subscription Rate: ", percent(subscription_rate, accuracy = 0.1), "<br>Contacts: ", comma(contacts)),
      hoverinfo = "text"
    ) %>%
      layout(
        xaxis = list(title = selected_label),
        yaxis = list(title = "Subscription Rate", tickformat = ".0%"),
        paper_bgcolor = "rgba(0,0,0,0)",
        plot_bgcolor = "rgba(255,253,248,0.8)",
        margin = list(l = 60, r = 20, t = 20, b = 90)
      )
  })

  output$data_table <- renderDT({
    filtered_data() %>%
      select(campaign_date, age, job, marital, education, contact, month, day_of_week, duration, campaign, previous, poutcome, subscription) %>%
      datatable(
        rownames = FALSE,
        options = list(pageLength = 8, scrollX = TRUE),
        caption = htmltools::tags$caption(
          style = "caption-side: top; text-align: left; color:#3f3d63; font-weight:700;",
          "Filtered campaign records based on the selected controls."
        )
      )
  })
}

shinyApp(ui = ui, server = server)
